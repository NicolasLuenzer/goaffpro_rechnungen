# Secrets fuer Docker Deployment
# Kopiere diese Datei zu .env und trage die echten Werte ein.
# Die .env-Datei wird NICHT ins Git-Repository aufgenommen.

# GoAffPro API
GOAFFPRO_API_KEY=

# ERPNext API (optional)
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# SMTP E-Mail-Versand
SMTP_PASSWORD=

# Authentifizierung
AUTH_SECRET=
ADMIN_PASSWORD=
