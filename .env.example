# Secrets fuer Docker Deployment
# Kopiere diese Datei zu .env und trage die echten Werte ein.
# Die .env-Datei wird NICHT ins Git-Repository aufgenommen.

# GoAffPro API
GOAFFPRO_API_KEY=

# SMTP E-Mail-Versand
GOAFFPRO_SMTP_HOST=
GOAFFPRO_SMTP_USERNAME=
SMTP_PASSWORD=
# Optional:
# GOAFFPRO_SMTP_PORT=587
# GOAFFPRO_SMTP_TLS=false
