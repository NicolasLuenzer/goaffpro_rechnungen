<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- Root element -->
  <xs:element name="EGeckoPersonenkonten">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="Personenkonto" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="kontenart" type="xs:string"/>
              <xs:element name="kontonummer" type="xs:string"/>
              <xs:element name="bezeichnung" type="xs:string"/>
              <xs:element name="Geschaeftspartner">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="nummer" type="xs:string"/>
                    <xs:element name="kzJuristischePerson" type="xs:string"/>
                    <xs:element name="anzeigename" type="xs:string"/>
                    <xs:element name="Personendaten">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="gueltigVon" type="xs:string"/>
                          <xs:element name="name1" type="xs:string"/>
                          <xs:element name="name2" type="xs:string"/>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="Anschrift">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="gueltigVon" type="xs:string"/>
                          <xs:element name="name1" type="xs:string"/>
                          <xs:element name="name2" type="xs:string"/>
                          <xs:element name="strasse" type="xs:string"/>
                          <xs:element name="hausnummer" type="xs:string"/>
                          <xs:element name="hausnummerZusatz" type="xs:string"/>
                          <xs:element name="plz" type="xs:string"/>
                          <xs:element name="ort" type="xs:string"/>
                          <xs:element name="landkennzeichen" type="xs:string"/>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="TeleKommunikationen">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="TeleKommunikation" maxOccurs="unbounded">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="qualifier" type="xs:string"/>
                                <xs:element name="art" type="xs:string"/>
                                <xs:element name="vorwahl" type="xs:string" minOccurs="0"/>
                                <xs:element name="rufnummer" type="xs:string" minOccurs="0"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="OnlineKommunikationen">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="OnlineKommunikation" maxOccurs="unbounded">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="qualifier" type="xs:string"/>
                                <xs:element name="art" type="xs:string"/>
                                <xs:element name="email" type="xs:string"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="Bankverbindungen">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="Bankverbindung" maxOccurs="unbounded">
                            <xs:complexType>
                              <xs:sequence>
                                <xs:element name="qualifier" type="xs:string"/>
                                <xs:element name="hauptbank" type="xs:string"/>
                                <xs:element name="iban" type="xs:string"/>
                                <xs:element name="kontobezeichnung" type="xs:string"/>
                              </xs:sequence>
                            </xs:complexType>
                          </xs:element>
                        </xs:sequence>
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="festkontoForderung" type="xs:string"/>
              <xs:element name="rechnungskonditionNr" type="xs:string"/>
              <xs:element name="zahlartNr" type="xs:string"/>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
      <xs:attribute name="objectgroupNr" type="xs:string"/>
      <xs:attribute name="datumFormat" type="xs:string"/>
    </xs:complexType>
  </xs:element>

</xs:schema>
